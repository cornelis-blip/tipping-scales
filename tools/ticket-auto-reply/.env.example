# ticket-auto-reply — environment

# Required. Private app token with Conversations read + write scopes
# (conversations.read, conversations.write) and CRM tickets read if you resolve
# the thread id from a ticket.
CONVERSATIONS_TOKEN=pat-na1-...

# ── webhook-handler.js only (the no-Operations-Hub path) ──────────────────────

# Optional. If set, inbound requests must carry a matching x-webhook-secret header.
# Add the same value as a custom header in the HubSpot "Send a webhook" action.
WEBHOOK_SHARED_SECRET=

# Optional. Fallback agent user id (reply is sent AS A-<userId>) when the webhook
# payload doesn't carry fromUserId.
DEFAULT_FROM_USER_ID=

# ── poller.js only (the no-Data-Hub path) ────────────────────────────────────
# Needs the token above with tickets read+WRITE too (to stamp the marker property).

# Required. HubSpot user id to send the reply as (goes out as agent A-<id>).
FROM_USER_ID=

# Required. The reply text the poller sends.
REPLY_MESSAGE=Thanks for getting in touch — we've received your ticket and are on it.

# Ticket property used to dedupe (skip already-replied tickets). Create it in your
# portal first (single-line text or datetime). Default if unset: auto_reply_sent_at.
MARKER_PROPERTY=auto_reply_sent_at

# Optional. Only reply to tickets in this pipeline stage id.
PIPELINE_STAGE_ID=

# Optional. Safety cap on replies per run (default 25).
MAX_PER_RUN=25

# Optional but recommended for first runs: "1" scans + logs without sending.
DRY_RUN=1
