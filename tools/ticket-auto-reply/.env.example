# ticket-auto-reply — environment

# Required. Private app token with Conversations read + write scopes
# (conversations.read, conversations.write) and CRM tickets read if you resolve
# the thread id from a ticket.
CONVERSATIONS_TOKEN=pat-na1-...

# ── webhook-handler.js only (the no-Operations-Hub path) ──────────────────────

# Optional. If set, inbound requests must carry a matching x-webhook-secret header.
# Add the same value as a custom header in the HubSpot "Send a webhook" action.
WEBHOOK_SHARED_SECRET=

# Optional. Fallback agent user id (reply is sent AS A-<userId>) when the webhook
# payload doesn't carry fromUserId.
DEFAULT_FROM_USER_ID=
