# sms-fanout — Twilio Function environment variables
# Set these in the Twilio Service → Environment Variables tab.

# Required (usually). Comma-separated list of webhooks to replay the inbound SMS to.
# Each receives a faithful copy of the original Twilio form payload, so anything
# that already accepts a Twilio SMS webhook works unchanged — including HubSpot's
# own inbound Twilio webhook URL, a Front/Zendesk/Help Scout channel webhook, etc.
FANOUT_WEBHOOK_URLS=https://api.frontapp.com/...,https://your-hubspot-inbound-webhook/...

# Optional. Set to "api" to ALSO log each reply as a Note on the matching HubSpot
# contact (looked up by phone). Any other value disables HubSpot API logging.
HUBSPOT_MODE=

# Required when HUBSPOT_MODE=api. Private app token with scopes:
#   crm.objects.contacts.read  and  crm.objects.notes.write (or the "notes" scope)
HUBSPOT_PRIVATE_APP_TOKEN=

# Optional. Country calling code used for the fallback contact lookup (default: 1).
HUBSPOT_PHONE_COUNTRY_CODE=1

# Auto-injected by the Twilio Functions runtime — do NOT set:
#   ACCOUNT_SID, AUTH_TOKEN
