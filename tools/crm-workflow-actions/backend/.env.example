# crm-actions backend — environment variables

# Required. Private app access token with CRM scopes for the objects you'll use:
#   crm.objects.contacts.read/write, crm.objects.companies.read/write,
#   crm.objects.deals.read/write, crm.objects.tickets.read/write,
#   crm.schemas.*.read (for the property dropdown).
HUBSPOT_TOKEN=pat-na1-...

# Required. Shared secret embedded as ?k=<value> in every actionUrl/optionsUrl
# you register in the app's hsmeta files. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACTION_SECRET=

# Optional. Port for the Node server adapter (default 3000).
PORT=3000
